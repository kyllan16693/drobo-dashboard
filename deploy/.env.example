# Copy to repo root: cp deploy/.env.example .env
# Never commit .env — fill secrets by hand on each host.

DROBO_HOST=192.168.1.144
DROBO_PORT=5000
POLL_INTERVAL=15

WEB_HOST=0.0.0.0
WEB_PORT=8765

# SSH telemetry (optional; NASD port 5000 needs no credentials)
DROBO_USERNAME=admin
DROBO_PASSWORD=

DROBO_SSH_THROUGHPUT=1
DROBO_THROUGHPUT_INTERVAL=5
# DROBO_NET_IFACE=eth0

DROBO_SSH_HARDWARE=1
DROBO_HARDWARE_INTERVAL=5

DROBO_DB_PATH=data/history.db

# Keep 0 in production unless you explicitly need identify/restart
DROBO_ENABLE_CONTROL=0
